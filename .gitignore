# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

certificates

# plans (local scratch)
/docs/plans/

# generated by next-image-export-optimizer (build artifacts)
**/nextImageExportOptimizer/
**/next-image-export-optimizer-hashes.json

# auto-generated article cover thumbnails (build artifacts)
/public/images/articles/generated/

# resume PDF copied from content/resume (build artifact)
/public/resume-shibbir-ahmed.pdf

# resume PDF source: ship only the .example.pdf placeholder and keep the real
# resume (resume-shibbir-ahmed.pdf) untracked so it is never committed/exposed
/content/resume/*.pdf
!/content/resume/*.example.pdf

# Article Studio recycle bin (dev-only soft deletes); never part of the site
/content/article_trash/