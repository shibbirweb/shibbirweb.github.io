# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

certificates

# plans (local scratch)
/docs/plans/

# generated by next-image-export-optimizer (build artifacts)
**/nextImageExportOptimizer/
**/next-image-export-optimizer-hashes.json

# auto-generated article cover thumbnails (build artifacts)
/public/images/articles/generated/

# auto-generated article OpenGraph raster images (build artifacts)
/public/og/

# resume PDF copied from content/resume (build artifact)
/public/resume-shibbir-ahmed.pdf

# service worker + helper generated by @serwist/next (build artifacts)
/public/sw.js
/public/sw.js.map
/public/swe-worker-*.js

# giscus comment theme generated from globals.css (build artifacts)
/public/giscus-light.css
/public/giscus-dark.css

# locally trusted localhost cert for `pnpm preview:https` (mkcert, local only)
/certificates/

# resume PDF source: ship only the .example.pdf placeholder and keep the real
# resume (resume-shibbir-ahmed.pdf) untracked so it is never committed/exposed
/content/resume/*.pdf
!/content/resume/*.example.pdf