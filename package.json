{
    "name": "shibbir-ahmed",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "gen:covers": "tsx scripts/generate-covers.ts",
        "gen:og": "tsx scripts/generate-og-images.ts",
        "gen:resume": "tsx scripts/prepare-resume.ts",
        "gen:giscus": "tsx scripts/generate-giscus-themes.ts",
        "gen:offline-fallback": "tsx scripts/generate-offline-fallback.ts",
        "gen:assets": "pnpm gen:covers && pnpm gen:resume && pnpm gen:giscus",
        "dev": "pnpm gen:assets && next-image-export-optimizer && next dev --turbopack",
        "dev:https": "pnpm gen:assets && next-image-export-optimizer && next dev --turbopack --experimental-https",
        "build": "pnpm gen:assets && pnpm gen:og && next build --webpack && next-image-export-optimizer && pnpm gen:offline-fallback",
        "start": "next start",
        "preview": "tsx scripts/serve-out.ts",
        "preview:https": "tsx scripts/serve-out.ts --https",
        "preview:docker": "mkdir -p certificates && HOST_UID=$(id -u) HOST_GID=$(id -g) docker compose up --build",
        "preview:docker:down": "docker compose down",
        "lint": "eslint"
    },
    "dependencies": {
        "@next/third-parties": "^15.3.3",
        "@serwist/next": "^9.5.11",
        "@serwist/window": "9.5.11",
        "@tailwindcss/typography": "^0.5.20",
        "clsx": "^2.1.1",
        "gemoji": "^8.1.0",
        "gray-matter": "^4.0.3",
        "marked": "^18.0.5",
        "marked-alert": "^2.1.2",
        "marked-emoji": "^2.0.3",
        "marked-footnote": "^1.4.0",
        "mermaid": "^11.16.0",
        "next": "16.1.5",
        "next-image-export-optimizer": "^1.20.1",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "shiki": "^4.3.0",
        "tailwind-merge": "^3.3.0"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3",
        "@resvg/resvg-js": "^2.6.2",
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "eslint": "^9",
        "eslint-config-next": "15.3.2",
        "eslint-config-prettier": "10.1.5",
        "prettier": "3.5.3",
        "prettier-plugin-tailwindcss": "0.6.11",
        "schema-dts": "^1.1.5",
        "serwist": "^9.5.11",
        "tailwindcss": "^4",
        "tsx": "^4.22.4",
        "typescript": "^5"
    }
}
